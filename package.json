{
	"name": "inline-toggles",
	"version": "1.0.0",
	"description": "Reliable inline toggles that save their state in Markdown. Features custom CSS attributes for rich styling in Live Preview while remaining clean and readable in Source mode.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"toggle",
		"inline",
		"notion",
		"collapsible",
		"markdown",
		"styling"
	],
	"author": "Niklas Tran",
	"license": "MIT",
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/json": "^1.2.0",
		"@types/node": "^20.12.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.58.1",
		"builtin-modules": "5.0.0",
		"esbuild": "0.27.4",
		"eslint": "^10.2.0",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"obsidian": "^1.12.3",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.40.0"
	}
}
